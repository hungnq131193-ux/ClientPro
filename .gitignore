# CI-only test tooling artifacts (app shipped vẫn zero-dependency)
node_modules/
package-lock.json
test-results/
playwright-report/
.lighthouseci/
coverage/
.nyc_output/

# Local logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.orig
*~
.DS_Store
Thumbs.db

# Generated screenshot evidence belongs in PR attachments or CI artifacts.
# Durable documentation images such as docs/screenshots/guide/onboarding.png remain trackable.
docs/screenshots/**/before/
docs/screenshots/**/after/
docs/screenshots/**/actual/
docs/screenshots/**/expected/
docs/screenshots/**/diff/
docs/screenshots/**/diffs/
docs/screenshots/**/generated/
docs/screenshots/**/review-artifacts/
